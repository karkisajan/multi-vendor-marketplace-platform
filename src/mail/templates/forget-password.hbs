<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <title>Reset Password</title>
  </head>

  <body
    style='
      margin: 0;
      padding: 0;
      background-color: #ffffff;
      font-family: Arial, sans-serif;
      color: #000000;
    '
  >
    <table
      width='100%'
      cellpadding='0'
      cellspacing='0'
      style='border-collapse: collapse;'
    >
      <tr>
        <td style='padding: 20px;'>
          <h2
            style='
              margin: 0 0 16px 0;
              font-weight: 600;
              font-size: 24px;
            '
          >
            Hey
            {{username}},
          </h2>

          <p
            style='
              margin: 0 0 12px 0;
              font-size: 16px;
              line-height: 1.6;
            '
          >
            We received a request to reset your password.
          </p>

          <p
            style='
              margin: 0 0 12px 0;
              font-size: 16px;
              line-height: 1.6;
            '
          >
            If you made this request, please click the link below to set a new
            password:
          </p>

          <p
            style='
              margin: 0 0 12px 0;
              font-size: 16px;
              line-height: 1.6;
            '
          >
            <a href='{{resetLink}}'>Reset Password {{resetLink}}</a>
          </p>

          <p
            style='
              margin: 0 0 12px 0;
              font-size: 16px;
              line-height: 1.6;
            '
          >
            This link will expire in
            15 mins.
          </p>

          <p
            style='
              margin: 0;
              font-size: 16px;
              line-height: 1.6;
            '
          >
            If you did not request a password reset, you can safely ignore this
            email.
          </p>

          <p
            style='
              margin: 24px 0 0 0;
              font-size: 15px;
            '
          >
            — Marketplace Team
          </p>
        </td>
      </tr>
    </table>
  </body>
</html>