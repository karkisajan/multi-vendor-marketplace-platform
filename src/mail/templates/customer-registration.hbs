<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <title>Welcome</title>
  </head>

  <body
    style='
      margin: 0;
      padding: 0;
      background-color: #ffffff;
      font-family: Arial, sans-serif;
      color: #000000;
    '
  >
    <table
      width='100%'
      cellpadding='0'
      cellspacing='0'
      style='border-collapse: collapse;'
    >
      <tr>
        <td style='padding: 20px;'>
          <h2
            style='
              margin: 0 0 16px 0;
              font-weight: 600;
              font-size: 24px;
            '
          >
            Hey
            {{username}},
          </h2>

          <p
            style='
              margin: 0 0 12px 0;
              font-size: 16px;
              line-height: 1.6;
            '
          >
            Welcome to Marketplace.
          </p>

          <p
            style='
              margin: 0 0 12px 0;
              font-size: 16px;
              line-height: 1.6;
            '
          >
            Thank you for creating an account with us. We're happy to have you
            here and excited for you to explore everything our marketplace has
            to offer.
          </p>

          <p
            style='
              margin: 0;
              font-size: 16px;
              line-height: 1.6;
            '
          >
            We hope you enjoy your experience.
          </p>

          <p
            style='
              margin: 24px 0 0 0;
              font-size: 15px;
            '
          >
            — Marketplace Team
          </p>
        </td>
      </tr>
    </table>
  </body>
</html>